<UserControl x:Class="YAInventory.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,16,20,20" MaxWidth="780">

            <!-- Header -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Settings" Style="{StaticResource H1}"/>
                    <TextBlock Text="Configure your shop details, sync, and printer"
                               Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource BtnPrimary}"
                        Command="{Binding SaveCommand}"
                        Content="💾 Save Settings" VerticalAlignment="Center" Margin="0"/>
            </Grid>

            <!-- ── Shop Details ────────────────────────────────────── -->
            <Border Style="{StaticResource GlassCard}" Padding="22,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="🏪" FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Text="Shop Details" Style="{StaticResource H3}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Separator/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Shop Name *" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding ShopName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="Phone" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0">
                            <TextBlock Text="Address" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}" Height="58"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Top" Padding="10,8"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,4,10,0">
                            <TextBlock Text="Email" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,4,0,0">
                            <TextBlock Text="Logo Image" Style="{StaticResource FormLabel}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Style="{StaticResource GlassInput}" IsReadOnly="True"
                                         Text="{Binding LogoPath}" MinWidth="120" Margin="0"/>
                                <Button Style="{StaticResource BtnSecondary}"
                                        Command="{Binding BrowseLogoCommand}"
                                        Content="Browse…" Margin="6,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Pricing & Discount ──────────────────────────────── -->
            <Border Style="{StaticResource GlassCard}" Padding="22,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="🏷" FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Text="Pricing &amp; Discount" Style="{StaticResource H3}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Separator/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Currency Symbol" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding CurrencySymbol, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Default Discount %" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding DefaultDiscount, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tax Rate %" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding TaxPercent, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#0E0A2030" CornerRadius="8" Padding="10,8" Margin="0,10,0,0"
                            BorderBrush="#20FFFFFF" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ℹ" Foreground="{StaticResource AccentPrimaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="Default discount is applied to all new products. Can be overridden per-product."
                                       Style="{StaticResource Caption}" Margin="6,0,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Cloud Sync ──────────────────────────────────────── -->
            <Border Style="{StaticResource GlassCard}" Padding="22,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="☁" FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Text="Cloud Sync — MongoDB Atlas" Style="{StaticResource H3}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Separator/>

                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="MongoDB Connection String" Style="{StaticResource FormLabel}"/>
                        <TextBox Style="{StaticResource GlassInput}"
                                 Text="{Binding MongoUri, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="mongodb+srv://user:pass@cluster.mongodb.net/"/>
                    </StackPanel>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Database Name" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding MongoDbName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Sync Interval (seconds)" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding SyncInterval, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,8" VerticalAlignment="Center">
                        <Button Style="{StaticResource BtnSecondary}"
                                Command="{Binding TestMongoCommand}"
                                Content="🔌 Test Connection" Margin="0"/>
                        <Border CornerRadius="6" Padding="10,5" Margin="8,0,0,0"
                                Background="#14FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                            <TextBlock Text="{Binding ConnectionStatus}"
                                       FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Border>
                    </StackPanel>

                    <Border Background="#0D0A2030" CornerRadius="8" Padding="12,10"
                            BorderBrush="#18FFFFFF" BorderThickness="1">
                        <TextBlock TextWrapping="Wrap" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}">
                            Leave blank to run in offline-only mode. When a connection string is
                            provided, the app will auto-sync in the background every
                            <Run Text="{Binding SyncInterval}"/> seconds.
                            Local data is always written first — the app works 100% offline.
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Printer ──────────────────────────────────────────── -->
            <Border Style="{StaticResource GlassCard}" Padding="22,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="🖨" FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Text="Thermal Printer" Style="{StaticResource H3}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Separator/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Select Printer" Style="{StaticResource FormLabel}"/>
                            <ComboBox Style="{StaticResource GlassCombo}"
                                      ItemsSource="{Binding AvailablePrinters}"
                                      SelectedItem="{Binding PrinterName}"
                                      Margin="0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource BtnSecondary}"
                                Command="{Binding RefreshPrintersCommand}"
                                Content="⟳ Refresh" VerticalAlignment="Bottom" Margin="10,4,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Inventory Thresholds ─────────────────────────────── -->
            <Border Style="{StaticResource GlassCard}" Padding="22,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="⚠" FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Text="Inventory Thresholds" Style="{StaticResource H3}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Separator/>
                    <StackPanel MaxWidth="220" HorizontalAlignment="Left" Margin="0,8,0,0">
                        <TextBlock Text="Low Stock Threshold (qty)" Style="{StaticResource FormLabel}"/>
                        <TextBox Style="{StaticResource GlassInput}"
                                 Text="{Binding LowStockThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Data Management ──────────────────────────────────── -->
            <Border Style="{StaticResource GlassCard}" Padding="22,18" Margin="0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="💾" FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Text="Data Management" Style="{StaticResource H3}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Separator/>

                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Local Data Folder" Style="{StaticResource FormLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding DataFolder}"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <Button Style="{StaticResource BtnSecondary}"
                                    Command="{Binding OpenDataFolderCommand}"
                                    Content="📂 Open" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Style="{StaticResource BtnSecondary}"
                                Command="{Binding BackupCommand}"
                                Content="📦 Create Backup (ZIP)" Margin="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
