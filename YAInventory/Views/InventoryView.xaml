<UserControl x:Class="YAInventory.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:YAInventory.ViewModels"
             FontFamily="Segoe UI"
             PreviewTextInput="UserControl_PreviewTextInput"
             PreviewKeyDown="UserControl_PreviewKeyDown">
    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header      -->
            <RowDefinition Height="Auto"/>  <!-- Stats row   -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar     -->
            <RowDefinition Height="*"/>     <!-- Grid        -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Inventory" Style="{StaticResource H1}"/>
                <TextBlock Text="Manage your products and stock levels"
                           Style="{StaticResource Caption}" Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource BtnSecondary}"
                        Command="{Binding ExportCommand}" Content="📥 Export" Margin="0"/>
                <Button Style="{StaticResource BtnPrimary}"
                        Command="{Binding AddProductCommand}" Content="＋ Add Product"/>
            </StackPanel>
        </Grid>

        <!-- ── Stats row ──────────────────────────────────────────── -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="3" Margin="0,0,0,12">
            <Border Style="{StaticResource GlassCard}" Padding="14,12" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource AccentGradient}">
                        <TextBlock Text="📦" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding TotalCount}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Total Products" Style="{StaticResource Caption}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource GlassCard}" Padding="14,12" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource AmberGradient}">
                        <TextBlock Text="⚠" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LowStockCount}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentAmberBrush}"/>
                        <TextBlock Text="Low Stock" Style="{StaticResource Caption}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource GlassCard}" Padding="14,12" Margin="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource RedGradient}">
                        <TextBlock Text="✕" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding OutOfStockCount}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentRedBrush}"/>
                        <TextBlock Text="Out of Stock" Style="{StaticResource Caption}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ── Toolbar / filters ─────────────────────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="120"/>
                    <ColumnDefinition Width="1.2*" MaxWidth="180"/>
                    <ColumnDefinition Width="1*" MaxWidth="150"/>
                    <ColumnDefinition Width="1.3*" MaxWidth="200"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Grid Grid.Column="0" Margin="0,0,8,0">
                    <TextBox Style="{StaticResource GlassInput}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0"/>
                    <TextBlock Text="🔍 Search name or barcode…"
                               Foreground="{StaticResource TextDimBrush}"
                               FontSize="11" IsHitTestVisible="False"
                               VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <ComboBox Grid.Column="1" Style="{StaticResource GlassCombo}"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding FilterCategory}"
                          Margin="0,0,8,0"/>

                <ComboBox Grid.Column="2" Style="{StaticResource GlassCombo}"
                          ItemsSource="{Binding StockFilters}"
                          SelectedItem="{Binding FilterStock}"
                          Margin="0,0,8,0"/>

                <!-- Barcode scan input -->
                <Grid Grid.Column="3">
                    <TextBox Style="{StaticResource GlassInput}"
                             Text="{Binding BarcodeBuffer, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="BarcodeBox_KeyDown"
                             Margin="0"/>
                    <TextBlock Text="📷 Scan barcode…"
                               Foreground="{StaticResource TextDimBrush}"
                               FontSize="11" IsHitTestVisible="False"
                               VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BarcodeBuffer}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BarcodeBuffer}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Data grid ─────────────────────────────────────────── -->
        <Border Grid.Row="3" Style="{StaticResource GlassCard}" Padding="0" Margin="0">
            <DataGrid ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      Style="{StaticResource GlassGrid}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      RowHeight="44"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Barcode"  Binding="{Binding Barcode}"  Width="120"/>
                    <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="*"/>
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="110"/>
                    <DataGridTextColumn Header="Price"    Binding="{Binding Price, StringFormat='₹{0:N2}'}" Width="90"/>
                    <DataGridTextColumn Header="Qty"      Binding="{Binding Quantity}" Width="60"/>
                    <DataGridTextColumn Header="Sale ₹"  Binding="{Binding SalePrice, StringFormat='₹{0:N2}'}" Width="80"/>

                    <!-- Stock status badge column -->
                    <DataGridTemplateColumn Header="Status" Width="105">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource StatusBadge}"
                                        Background="{Binding StockStatus, Converter={StaticResource StockBg}}"
                                        Margin="2,3">
                                    <TextBlock Text="{Binding StockStatusLabel}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{Binding StockStatus, Converter={StaticResource StockColor}}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Actions column -->
                    <DataGridTemplateColumn Header="Actions" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource BtnIcon}"
                                            Command="{Binding DataContext.EditProductCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Edit" Width="28" Height="28"
                                            Background="#156366F1" Margin="0,0,6,0">
                                        <TextBlock Text="✏️" FontSize="12"/>
                                    </Button>
                                    <Button Style="{StaticResource BtnIcon}"
                                            Command="{Binding DataContext.UpdateQtyCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Update Quantity" Width="28" Height="28"
                                            Background="#1522C55E" Margin="0,0,6,0">
                                        <TextBlock Text="📦" FontSize="12"/>
                                    </Button>
                                    <Button Style="{StaticResource BtnIcon}"
                                            Command="{Binding DataContext.DeleteProductCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Delete" Width="28" Height="28"
                                            Background="#15EF4444">
                                        <TextBlock Text="🗑️" FontSize="12"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ── Add/Edit product dialog overlay ──────────────────── -->
        <Grid Grid.Row="0" Grid.RowSpan="4"
              Visibility="{Binding ShowDialog, Converter={StaticResource BoolToVis}}"
              Background="#B5000010" ZIndex="50">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="500" MaxWidth="520" MinWidth="340"
                    Style="{StaticResource GlassCard}"
                    Background="#1E1E3A" Padding="28,24" Margin="0">
                <Border.Effect>
                    <DropShadowEffect Color="#6366F1" BlurRadius="30" ShadowDepth="0" Opacity="0.35"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Margin="0,0,0,6">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource H2}">
                                <Setter Property="Text" Value="Add Product"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Text" Value="Edit Product"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Separator Margin="0,0,0,14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Name -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                            <TextBlock Text="Product Name *" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding DialogProduct.Name, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Barcode -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,10">
                            <TextBlock Text="Barcode *" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding DialogProduct.Barcode, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Category -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                            <TextBlock Text="Category" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding DialogProduct.Category, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Price -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,10">
                            <TextBlock Text="Price (₹) *" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding DialogProduct.Price, UpdateSourceTrigger=PropertyChanged, StringFormat='N2'}"/>
                        </StackPanel>

                        <!-- Quantity -->
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                            <TextBlock Text="Quantity" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding DialogProduct.Quantity, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Sale Price -->
                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Sale Price (₹)" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource GlassInput}"
                                     Text="{Binding DialogProduct.SalePrice, UpdateSourceTrigger=PropertyChanged, StringFormat='N2'}"/>
                            <TextBlock Text="Leave 0 to sell at regular price" 
                                       Foreground="{StaticResource TextDimBrush}" FontSize="9" Margin="2,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,14,0,12"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource BtnSecondary}"
                                Command="{Binding CancelDialogCommand}"
                                Content="Cancel" Width="90" Margin="0"/>
                        <Button Style="{StaticResource BtnPrimary}"
                                Command="{Binding SaveProductCommand}"
                                Content="Save Product" Width="120"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Update Quantity dialog overlay ──────────────────────── -->
        <Grid Grid.Row="0" Grid.RowSpan="4"
              Visibility="{Binding ShowQtyDialog, Converter={StaticResource BoolToVis}}"
              Background="#B5000010" ZIndex="50">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="420" MaxWidth="460" MinWidth="300"
                    Style="{StaticResource GlassCard}"
                    Background="#1A1F3A" Padding="28,24" Margin="0">
                <Border.Effect>
                    <DropShadowEffect Color="#22C55E" BlurRadius="30" ShadowDepth="0" Opacity="0.35"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Title -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="📦" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Add Stock" Style="{StaticResource H2}"/>
                    </StackPanel>

                    <!-- Product name -->
                    <TextBlock Text="{Binding QtyDialogProduct.Name}"
                               Foreground="{StaticResource TextDimBrush}"
                               FontSize="12" Margin="0,0,0,12"
                               TextTrimming="CharacterEllipsis"/>

                    <Separator Margin="0,0,0,16"/>

                    <!-- Current qty info + preview -->
                    <Border Background="#12FFFFFF" CornerRadius="8" Padding="12,10" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Current -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Current: " Foreground="{StaticResource TextDimBrush}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding QtyDialogProduct.Quantity}"
                                           Foreground="{StaticResource AccentPrimaryBrush}"
                                           FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- + -->
                            <TextBlock Grid.Column="1" Text=" + " Foreground="{StaticResource TextDimBrush}" FontSize="13" VerticalAlignment="Center"/>
                            <!-- Added -->
                            <TextBlock Grid.Column="2" Text="{Binding NewQuantity}"
                                       Foreground="#22C55E" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                            <!-- = -->
                            <TextBlock Grid.Column="3" Text=" = " Foreground="{StaticResource TextDimBrush}" FontSize="13" VerticalAlignment="Center"/>
                            <!-- Total -->
                            <TextBlock Grid.Column="4" Text="{Binding QtyPreviewTotal}"
                                       Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Qty to add input -->
                    <TextBlock Text="Quantity to Add *" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource GlassInput}"
                             Text="{Binding NewQuantity, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"
                             x:Name="QtyInputBox"/>

                    <Separator Margin="0,0,0,14"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource BtnSecondary}"
                                Command="{Binding CancelQtyDialogCommand}"
                                Content="Cancel" Width="90" Margin="0"/>
                        <Button Style="{StaticResource BtnPrimary}"
                                Command="{Binding SaveQtyCommand}"
                                Content="Update Qty" Width="120"
                                Background="#22C55E"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
