<UserControl x:Class="YAInventory.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:YAInventory.ViewModels"
             FontFamily="Segoe UI">
    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Row 0: Title + Export buttons  -->
            <RowDefinition Height="Auto"/>   <!-- Row 1: Date range filter bar   -->
            <RowDefinition Height="Auto"/>   <!-- Row 2: KPI cards               -->
            <RowDefinition Height="Auto"/>   <!-- Row 3: Sales chart             -->
            <RowDefinition Height="*"/>      <!-- Row 4: Bottom tables           -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Header ────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Reports" Style="{StaticResource H1}"/>
                <TextBlock Text="Sales analytics and inventory insights"
                           Style="{StaticResource Caption}" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Export buttons — isolated in their own column, no overlap -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource BtnSecondary}"
                        Command="{Binding ExportInventoryCommand}"
                        Content="📦 Export Inventory" Margin="0"/>
                <Button Style="{StaticResource BtnPrimary}"
                        Command="{Binding ExportSalesCommand}"
                        Content="📥 Export Sales"/>
            </StackPanel>
        </Grid>

        <!-- ── Row 1: Date range filter bar ─────────────────────────── -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}"
                Padding="14,10" Margin="0,0,0,10">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- From date -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="From:" Style="{StaticResource Body}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker Style="{StaticResource GlassDatePicker}"
                                SelectedDate="{Binding FromDate}"
                                Width="120"
                                VerticalAlignment="Center"/>
                </StackPanel>

                <!-- To date -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="To:" Style="{StaticResource Body}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker Style="{StaticResource GlassDatePicker}"
                                SelectedDate="{Binding ToDate}"
                                Width="120"
                                VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Divider -->
                <Rectangle Width="1" Height="22" Fill="#25FFFFFF"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>

                <!-- Quick-select buttons -->
                <Button Style="{StaticResource BtnSecondary}" Command="{Binding SetTodayCommand}"
                        Content="Today" Margin="0,0,4,0"/>
                <Button Style="{StaticResource BtnSecondary}" Command="{Binding SetWeekCommand}"
                        Content="Last 7 Days" Margin="0,0,4,0"/>
                <Button Style="{StaticResource BtnSecondary}" Command="{Binding SetMonthCommand}"
                        Content="This Month" Margin="0"/>

            </WrapPanel>
        </Border>

        <!-- ── Row 2: KPI cards ──────────────────────────────────────── -->
        <UniformGrid Grid.Row="2" Rows="1" Columns="5" Margin="0,0,0,10">

            <Border Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1040" Offset="0"/>
                        <GradientStop Color="#2A1860" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="💰 Revenue" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding TotalRevenue, Converter={StaticResource Currency}}"
                               FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,6,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0A2818" Offset="0"/>
                        <GradientStop Color="#103820" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="🧾 Transactions" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding TotalTransactions}"
                               FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0A1828" Offset="0"/>
                        <GradientStop Color="#0A2838" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="📊 Avg Order" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding AvgOrderValue, Converter={StaticResource Currency}}"
                               FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,6,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#281000" Offset="0"/>
                        <GradientStop Color="#381800" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="🏷 Discount" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding TotalDiscount, Converter={StaticResource Currency}}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentAmberBrush}" Margin="0,6,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCard}" Margin="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#10120A" Offset="0"/>
                        <GradientStop Color="#1A1A0A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="🏦 Tax Collected" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding TotalTax, Converter={StaticResource Currency}}"
                               FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,6,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- ── Row 3: Sales trend chart ──────────────────────────────── -->
        <Border Grid.Row="3" Style="{StaticResource GlassCard}"
                Padding="18,14" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="📈 Sales Trend" Style="{StaticResource H3}" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding ChartData}" Height="120">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SalesBarData}">
                            <Grid Height="120">
                                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Amount, Converter={StaticResource CompactNum}}"
                                               FontSize="9" Foreground="{StaticResource TextMutedBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                    <Border Width="22" MinHeight="4"
                                            CornerRadius="4,4,0,0" HorizontalAlignment="Center">
                                        <Border.Height>
                                            <MultiBinding Converter="{StaticResource BarHeight}">
                                                <Binding Path="Amount"/>
                                                <Binding Path="ItemsSource"
                                                         RelativeSource="{RelativeSource AncestorType=ItemsControl}"
                                                         Converter="{StaticResource MaxValue}"/>
                                            </MultiBinding>
                                        </Border.Height>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#06B6D4" Offset="0"/>
                                                <GradientStop Color="#0891B2" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Text="{Binding Label}"
                                               FontSize="9" Foreground="{StaticResource TextMutedBrush}"
                                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ── Row 4: Bottom tables ──────────────────────────────────── -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260" MinWidth="220" MaxWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- Transaction History -->
            <Border Grid.Column="0" Style="{StaticResource GlassCard}"
                    Padding="14" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="📋 Transaction History" Style="{StaticResource H3}"
                               Margin="0,0,0,8"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SalesList}"
                              Style="{StaticResource GlassGrid}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Invoice"  Binding="{Binding SaleId}"     Width="*"/>
                            <DataGridTextColumn Header="Date"     Binding="{Binding SaleDate, StringFormat='dd MMM yy HH:mm'}" Width="130"/>
                            <DataGridTextColumn Header="Items"    Binding="{Binding Items.Count}" Width="50"/>
                            <DataGridTextColumn Header="Discount" Binding="{Binding Discount, StringFormat='₹{0:N2}'}" Width="75"/>
                            <DataGridTextColumn Header="Total"    Binding="{Binding Total, StringFormat='₹{0:N2}'}"    Width="85"/>
                            <DataGridTextColumn Header="Payment"  Binding="{Binding PaymentMethod}" Width="75"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Top Products -->
            <Border Grid.Column="1" Style="{StaticResource GlassCard}" Padding="14" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="🏆 Top Products" Style="{StaticResource H3}"
                               Margin="0,0,0,8"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding TopProducts}"
                              Style="{StaticResource GlassGrid}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="Qty"     Binding="{Binding Quantity}" Width="42"/>
                            <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat='₹{0:N0}'}" Width="75"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
