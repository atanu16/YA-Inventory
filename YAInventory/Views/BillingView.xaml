<UserControl x:Class="YAInventory.Views.BillingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI"
             Loaded="UserControl_Loaded">
    <Grid Margin="20,16,20,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400"/>      <!-- Cart -->
            <ColumnDefinition Width="290" MinWidth="260" MaxWidth="340"/> <!-- Totals -->
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  LEFT: Cart                                                -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header           -->
                <RowDefinition Height="Auto"/>  <!-- Barcode + search -->
                <RowDefinition Height="*"/>     <!-- Cart items       -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Billing / POS" Style="{StaticResource H1}"/>
                    <TextBlock Text="Scan barcode or search to add items"
                               Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource BtnDanger}"
                        Command="{Binding ClearCartCommand}"
                        Content="🗑 Clear Cart" VerticalAlignment="Center" Margin="0"/>
            </Grid>

            <!-- Scan / Search bar -->
            <Border Grid.Row="1" Style="{StaticResource GlassCard}"
                    Padding="14,10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Barcode scan input -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="📷  BARCODE SCANNER" Style="{StaticResource Caption}"
                                   FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="BarcodeBox"
                                 Style="{StaticResource GlassInput}"
                                 Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="BarcodeBox_KeyDown"
                                 Margin="0"/>
                    </StackPanel>

                    <Rectangle Grid.Column="1" Width="1" Fill="#22FFFFFF"
                                Margin="14,0" VerticalAlignment="Stretch"/>

                    <!-- Product search -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="🔍  SEARCH PRODUCT" Style="{StaticResource Caption}"
                                   FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Grid>
                            <TextBox x:Name="SearchBox" Style="{StaticResource GlassInput}"
                                     Text="{Binding ProductSearch, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0"/>
                            <!-- Dropdown results -->
                            <Popup IsOpen="{Binding HasSearchResults, Mode=OneWay}"
                                   PlacementTarget="{Binding ElementName=SearchBox}"
                                   StaysOpen="False" AllowsTransparency="True">
                                <Border Background="#1E1E3A" BorderBrush="#30FFFFFF" BorderThickness="1"
                                        CornerRadius="8" MinWidth="240">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000" BlurRadius="14" ShadowDepth="4" Opacity="0.5"/>
                                    </Border.Effect>
                                    <ItemsControl ItemsSource="{Binding SearchResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource BtnIcon}"
                                                        Command="{Binding DataContext.AddToCartCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Padding="12,8" Margin="0">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="12" Foreground="White"/>
                                                        <TextBlock Text="{Binding Barcode}" Style="{StaticResource Caption}"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Cart items table -->
            <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="0" Margin="0">
                <Grid>
                    <DataGrid ItemsSource="{Binding CartItems}"
                              Style="{StaticResource GlassGrid}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product"  Binding="{Binding Name}"       Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Price"    Binding="{Binding UnitPrice, StringFormat='₹{0:N2}'}" Width="80" IsReadOnly="True"/>

                            <!-- Qty with +/- buttons -->
                            <DataGridTemplateColumn Header="Qty" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource BtnIcon}"
                                                    Command="{Binding DataContext.DecrQtyCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Width="22" Height="22" Margin="0">
                                                <TextBlock Text="−" FontSize="13" Foreground="White"/>
                                            </Button>
                                            <TextBlock Text="{Binding Quantity}"
                                                       Width="26" TextAlignment="Center"
                                                       FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                            <Button Style="{StaticResource BtnIcon}"
                                                    Command="{Binding DataContext.IncrQtyCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Width="22" Height="22" Margin="0">
                                                <TextBlock Text="+" FontSize="13" Foreground="White"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Disc %"
                                                Binding="{Binding DiscountPercent, UpdateSourceTrigger=PropertyChanged}"
                                                Width="60"/>
                            <DataGridTextColumn Header="Disc ₹"
                                                Binding="{Binding DiscountFlat, UpdateSourceTrigger=PropertyChanged}"
                                                Width="60"/>
                            <DataGridTextColumn Header="Total"
                                                Binding="{Binding Total, StringFormat='₹{0:N2}'}"
                                                Width="90" IsReadOnly="True"/>

                            <!-- Remove button -->
                            <DataGridTemplateColumn Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource BtnIcon}"
                                                Command="{Binding DataContext.RemoveFromCartCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Width="28" Height="28" Margin="0">
                                            <TextBlock Text="✕" FontSize="11" Foreground="{StaticResource AccentRedBrush}"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty cart message -->
                    <TextBlock Text="Cart is empty — scan a barcode to begin"
                               Style="{StaticResource Caption}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding CartItems.Count,
                                   Converter={StaticResource BoolToVis}, ConverterParameter=Invert, Mode=OneWay}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  RIGHT: Order summary panel                                -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Style="{StaticResource GlassCard}"
                Padding="18,16" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Title     -->
                    <RowDefinition Height="*"/>     <!-- Totals    -->
                    <RowDefinition Height="Auto"/>  <!-- Payment   -->
                    <RowDefinition Height="Auto"/>  <!-- Buttons   -->
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0" Text="Order Summary" Style="{StaticResource H3}" Margin="0,0,0,10"/>
                <Separator Grid.Row="0" VerticalAlignment="Bottom"/>

                <!-- Totals -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,4,0,4">
                    <StackPanel>
                        <!-- Subtotal -->
                        <Grid Margin="0,6,0,0">
                            <TextBlock Text="Subtotal" Style="{StaticResource Body}"/>
                            <TextBlock Text="{Binding Subtotal, Converter={StaticResource Currency}}"
                                       Foreground="White" FontSize="13" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Cart discount % -->
                        <TextBlock Text="Cart Discount %" Style="{StaticResource Caption}" Margin="0,10,0,2"/>
                        <TextBox Style="{StaticResource GlassInput}"
                                 Text="{Binding CartDiscountPercent, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0"/>

                        <!-- Cart discount flat -->
                        <TextBlock Text="Flat Discount (₹)" Style="{StaticResource Caption}" Margin="0,8,0,2"/>
                        <TextBox Style="{StaticResource GlassInput}"
                                 Text="{Binding CartDiscountFlat, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0"/>

                        <!-- Discount total -->
                        <Grid Margin="0,10,0,0">
                            <TextBlock Text="Discount" Style="{StaticResource Body}"/>
                            <TextBlock Text="{Binding DiscountAmount, StringFormat='-₹{0:N2}'}"
                                       Foreground="{StaticResource AccentAmberBrush}"
                                       FontSize="13" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Tax -->
                        <Grid Margin="0,6,0,0">
                            <TextBlock Text="Tax" Style="{StaticResource Body}"/>
                            <TextBlock Text="{Binding TaxAmount, Converter={StaticResource Currency}}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="13" HorizontalAlignment="Right"/>
                        </Grid>

                        <Separator Margin="0,10,0,4"/>

                        <!-- Final total -->
                        <Grid Margin="0,0,0,2">
                            <TextBlock Text="TOTAL" FontSize="15" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{Binding FinalTotal, Converter={StaticResource Currency}}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource AccentPrimaryBrush}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Separator Grid.Row="1" VerticalAlignment="Bottom"/>

                <!-- Payment method -->
                <StackPanel Grid.Row="2" Margin="0,8,0,10">
                    <TextBlock Text="Payment Method" Style="{StaticResource Caption}" Margin="0,0,0,2"/>
                    <ComboBox Style="{StaticResource GlassCombo}"
                              ItemsSource="{Binding PaymentMethods}"
                              SelectedItem="{Binding PaymentMethod}"
                              Margin="0"/>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Row="3">
                    <Button Style="{StaticResource BtnSuccess}"
                            Command="{Binding CheckoutCommand}"
                            Content="✓  Checkout &amp; Print"
                            FontSize="14" Height="44" Margin="0,0,0,8"/>
                    <Button Style="{StaticResource BtnSecondary}"
                            Command="{Binding PrintLastReceiptCommand}"
                            Content="🖨  Reprint Last Receipt"
                            FontSize="12" Margin="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
