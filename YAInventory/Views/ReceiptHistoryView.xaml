<UserControl x:Class="YAInventory.Views.ReceiptHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <Grid Margin="20,16,20,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="340"/>
            <ColumnDefinition Width="340" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════  LEFT: List + Filters ═══════════════════════════ -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Receipt History" Style="{StaticResource H1}"/>
                    <TextBlock Text="Search and view all past sales receipts"
                               Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource BtnPrimary}"
                        Command="{Binding RefreshCommand}"
                        Content="⟳  Refresh" VerticalAlignment="Center" Margin="0"/>
            </Grid>

            <!-- Date range filter bar -->
            <Border Grid.Row="1" Style="{StaticResource GlassCard}"
                    Padding="14,10" Margin="0,0,0,8">
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="From:" Style="{StaticResource Body}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker Style="{StaticResource GlassDatePicker}"
                                    SelectedDate="{Binding FromDate}"
                                    Width="120" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                        <TextBlock Text="To:" Style="{StaticResource Body}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker Style="{StaticResource GlassDatePicker}"
                                    SelectedDate="{Binding ToDate}"
                                    Width="120" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Rectangle Width="1" Height="22" Fill="#25FFFFFF"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Style="{StaticResource BtnSecondary}" Command="{Binding SetTodayCommand}"
                            Content="Today" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnSecondary}" Command="{Binding SetWeekCommand}"
                            Content="Last 7 Days" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnSecondary}" Command="{Binding SetMonthCommand}"
                            Content="This Month" Margin="0"/>
                </WrapPanel>
            </Border>

            <!-- Search bar -->
            <Border Grid.Row="2" Style="{StaticResource GlassCard}"
                    Padding="12,8" Margin="0,0,0,8">
                <Grid>
                    <TextBox Style="{StaticResource GlassInput}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0"/>
                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False"
                                VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="🔍  Search by receipt number, product name, barcode…"
                                   FontSize="12" Foreground="{StaticResource TextDimBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <Button Style="{StaticResource BtnIcon}"
                            Command="{Binding ClearSearchCommand}"
                            HorizontalAlignment="Right"
                            Width="28" Height="28" Margin="0,0,2,0">
                        <TextBlock Text="✕" FontSize="11"
                                   Foreground="{StaticResource TextDimBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Receipt list -->
            <Border Grid.Row="3" Style="{StaticResource GlassCard}" Padding="0">
                <Grid>
                    <ListBox ItemsSource="{Binding FilteredSales}"
                             SelectedItem="{Binding SelectedReceipt}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background"   Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush"  Value="#12FFFFFF"/>
                                <Setter Property="Padding"      Value="14,10"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Row"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}"
                                                    Cursor="Hand">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Row" Property="Background" Value="#16FFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Row" Property="Background" Value="#22FFFFFF"/>
                                                    <Setter TargetName="Row" Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                                    <Setter TargetName="Row" Property="BorderThickness" Value="2,0,0,0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding SaleId}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentPrimaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding SaleDate, StringFormat='dd MMM yyyy  HH:mm'}"
                                                       Style="{StaticResource Caption}"/>
                                            <TextBlock Text=" · " Style="{StaticResource Caption}"/>
                                            <TextBlock Text="{Binding PaymentMethod}"
                                                       Style="{StaticResource Caption}"/>
                                            <TextBlock Text=" · " Style="{StaticResource Caption}"/>
                                            <TextBlock Text="{Binding Items.Count, StringFormat='{}{0} item(s)'}"
                                                       Style="{StaticResource Caption}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Total, StringFormat='₹{0:N2}'}"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding FilteredSales.Count,
                                    Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <TextBlock Text="🧾" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="No receipts found" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Try a different date range or search term"
                                   Style="{StaticResource Caption}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════  RIGHT: Detail Panel ═══════════════════════════ -->
        <Border Grid.Column="1" Style="{StaticResource GlassCard}" Padding="0">
            <Grid>
                <!-- Placeholder when nothing selected -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding HasSelection,
                                Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                    <TextBlock Text="👆" FontSize="34" HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a receipt" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                    <TextBlock Text="Click any row on the left to view its full details"
                               Style="{StaticResource Caption}" HorizontalAlignment="Center"
                               MaxWidth="200" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Receipt detail (only when selected) -->
                <Grid Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Receipt header banner -->
                    <Border Grid.Row="0" Background="#0D0D20"
                            CornerRadius="12,12,0,0" Padding="18,14">
                        <Border.Effect>
                            <DropShadowEffect Color="#6366F1" BlurRadius="14" ShadowDepth="0" Opacity="0.25"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="RECEIPT" FontSize="9" FontWeight="Bold" Opacity="0.4"
                                           Foreground="White" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding SelectedReceipt.SaleId}"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource AccentPrimaryBrush}"/>
                                <TextBlock Text="{Binding SelectedReceipt.SaleDate, StringFormat='dd MMM yyyy, HH:mm'}"
                                           Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" CornerRadius="20"
                                    Background="#1A6366F1" BorderBrush="{StaticResource AccentPrimaryBrush}"
                                    BorderThickness="1" Padding="10,4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedReceipt.PaymentMethod}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentPrimaryBrush}"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Meta strip (Cashier / Items / Payment) -->
                    <UniformGrid Grid.Row="1" Rows="1" Columns="3" Background="#0A0A18">
                        <Border BorderBrush="#12FFFFFF" BorderThickness="0,0,1,0" Padding="14,8">
                            <StackPanel>
                                <TextBlock Text="CASHIER" FontSize="8" Opacity="0.5" Foreground="White" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedReceipt.CashierName, FallbackValue='—'}"
                                           FontSize="11" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#12FFFFFF" BorderThickness="0,0,1,0" Padding="14,8">
                            <StackPanel>
                                <TextBlock Text="ITEMS" FontSize="8" Opacity="0.5" Foreground="White" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedReceipt.Items.Count}"
                                           FontSize="11" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <Border Padding="14,8">
                            <StackPanel>
                                <TextBlock Text="PAYMENT" FontSize="8" Opacity="0.5" Foreground="White" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedReceipt.PaymentMethod}"
                                           FontSize="11" Foreground="White"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Line items DataGrid -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding SelectedItems}"
                              Style="{StaticResource GlassGrid}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserSortColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding Name}"           Width="*"/>
                            <DataGridTextColumn Header="Qty"     Binding="{Binding Quantity}"       Width="40"/>
                            <DataGridTextColumn Header="Price"   Binding="{Binding UnitPrice, StringFormat='₹{0:N2}'}" Width="72"/>
                            <DataGridTextColumn Header="Saved"   Binding="{Binding DiscountAmount, StringFormat='₹{0:N2}'}" Width="60"/>
                            <DataGridTextColumn Header="Total"   Binding="{Binding Total, StringFormat='₹{0:N2}'}" Width="72"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Totals summary -->
                    <Border Grid.Row="3" Background="#0A0A18"
                            Padding="16,10" BorderBrush="#18FFFFFF" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Subtotal" Style="{StaticResource Body}"/>
                                <TextBlock Text="{Binding SelectedReceipt.Subtotal, StringFormat='₹{0:N2}'}"
                                           Foreground="White" FontSize="13" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Discount" Style="{StaticResource Body}"/>
                                <TextBlock Text="{Binding SelectedReceipt.Discount, StringFormat='-₹{0:N2}'}"
                                           Foreground="{StaticResource AccentAmberBrush}"
                                           FontSize="13" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Tax" Style="{StaticResource Body}"/>
                                <TextBlock Text="{Binding SelectedReceipt.TaxAmount, StringFormat='₹{0:N2}'}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="13" HorizontalAlignment="Right"/>
                            </Grid>
                            <Separator Margin="0,6"/>
                            <Grid>
                                <TextBlock Text="TOTAL" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{Binding SelectedReceipt.Total, StringFormat='₹{0:N2}'}"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource AccentPrimaryBrush}"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="12,8,12,8">
                        <Button Style="{StaticResource BtnSecondary}"
                                Command="{Binding CloseDetailCommand}"
                                Content="✕  Close" Margin="0"/>
                        <Button Style="{StaticResource BtnPrimary}"
                                Command="{Binding PrintReceiptCommand}"
                                Content="🖨  Reprint"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
