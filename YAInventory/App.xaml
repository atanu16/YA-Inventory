<Application x:Class="YAInventory.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:YAInventory.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters -->
            <conv:BoolToVisibilityConverter    x:Key="BoolToVis"/>
            <conv:StockStatusToColorConverter  x:Key="StockColor"/>
            <conv:StockStatusToBgConverter     x:Key="StockBg"/>
            <conv:CurrencyConverter            x:Key="Currency"/>
            <conv:CompactNumberConverter       x:Key="CompactNum"/>
            <conv:StringEqualsConverter        x:Key="StrEq"/>
            <conv:BarHeightConverter           x:Key="BarHeight"/>
            <conv:MaxValueConverter            x:Key="MaxValue"/>

            <!-- Global font -->
            <Style TargetType="Window">
                <Setter Property="FontFamily" Value="Segoe UI"/>
            </Style>
            <Style TargetType="UserControl">
                <Setter Property="FontFamily" Value="Segoe UI"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
