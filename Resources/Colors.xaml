<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Background ──────────────────────────────────────────────────── -->
    <Color x:Key="BgDeep">#0A0A1A</Color>
    <Color x:Key="BgMid" >#12122A</Color>
    <Color x:Key="BgCard">#1A1A35</Color>

    <!-- ── Glass panels ────────────────────────────────────────────────── -->
    <Color x:Key="GlassWhite">  #1AFFFFFF</Color>   <!-- 10% white -->
    <Color x:Key="GlassBorder"> #30FFFFFF</Color>   <!-- 19% white -->
    <Color x:Key="GlassSidebar">#0D0D20FF</Color>

    <!-- ── Accent palette ──────────────────────────────────────────────── -->
    <Color x:Key="AccentPrimary">  #6366F1</Color>  <!-- indigo  -->
    <Color x:Key="AccentSecondary">#8B5CF6</Color>  <!-- violet  -->
    <Color x:Key="AccentCyan">     #06B6D4</Color>  <!-- cyan    -->
    <Color x:Key="AccentGreen">    #10B981</Color>  <!-- emerald -->
    <Color x:Key="AccentAmber">    #F59E0B</Color>  <!-- amber   -->
    <Color x:Key="AccentRed">      #EF4444</Color>  <!-- red     -->
    <Color x:Key="AccentPink">     #EC4899</Color>  <!-- pink    -->

    <!-- ── Text ────────────────────────────────────────────────────────── -->
    <Color x:Key="TextPrimary">#F8FAFC</Color>
    <Color x:Key="TextMuted">  #94A3B8</Color>
    <Color x:Key="TextDim">    #475569</Color>

    <!-- ── Gradient brushes ────────────────────────────────────────────── -->
    <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0A0A1A" Offset="0"/>
        <GradientStop Color="#12103A" Offset="0.4"/>
        <GradientStop Color="#0A1628" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6366F1" Offset="0"/>
        <GradientStop Color="#8B5CF6" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GreenGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#059669" Offset="0"/>
        <GradientStop Color="#10B981" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CyanGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0891B2" Offset="0"/>
        <GradientStop Color="#06B6D4" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AmberGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D97706" Offset="0"/>
        <GradientStop Color="#F59E0B" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="RedGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#DC2626" Offset="0"/>
        <GradientStop Color="#EF4444" Offset="1"/>
    </LinearGradientBrush>

    <!-- ── Solid brushes ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="TextDimBrush"       Color="{StaticResource TextDim}"/>
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimary}"/>
    <SolidColorBrush x:Key="AccentGreenBrush"   Color="{StaticResource AccentGreen}"/>
    <SolidColorBrush x:Key="AccentAmberBrush"   Color="{StaticResource AccentAmber}"/>
    <SolidColorBrush x:Key="AccentRedBrush"     Color="{StaticResource AccentRed}"/>
    <SolidColorBrush x:Key="AccentPinkBrush"    Color="{StaticResource AccentPink}"/>
    <SolidColorBrush x:Key="GlassBorderBrush"   Color="{StaticResource GlassBorder}"/>

    <!-- Glass panel background (semi-transparent) -->
    <SolidColorBrush x:Key="GlassFillBrush" Color="#18FFFFFF"/>
    <SolidColorBrush x:Key="SidebarBrush"   Color="#0D0D20"/>
    <SolidColorBrush x:Key="CardBrush"      Color="#1A1A35"/>
    <SolidColorBrush x:Key="InputBrush"     Color="#0F0F2A"/>

</ResourceDictionary>
